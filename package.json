{
  "name": "@supagloo/nodejs-dbos",
  "version": "0.0.1",
  "private": true,
  "description": "Supagloo DBOS worker: statically-registered durable workflows + queues (git-ops, ai-generation, render).",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "postinstall": "check-prisma-version",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@dbos-inc/dbos-sdk": "^4.23.6",
    "@prisma/client": "7.8.0",
    "@supagloo/database-lib": "file:./supagloo-database-lib",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/pg": "^8.11.10",
    "pg": "^8.13.1",
    "prisma": "7.8.0",
    "tsx": "^4.23.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.10"
  }
}
