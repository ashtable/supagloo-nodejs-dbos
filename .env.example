# supagloo-nodejs-dbos local-dev env (matches the root Docker Compose stack).
#
# The DBOS worker needs TWO Postgres connection strings against the single
# postgres:17 container's two logical databases (root pg-init creates both):
#
#   DATABASE_URL       : the APP db (`supagloo`). Workflows write domain rows here
#                        via db-lib's Prisma client.
#   DBOS_DATABASE_URL  : the DBOS SYSTEM db (`supagloo_dbos`). DBOS checkpoints +
#                        queues; DBOS creates its own tables here on launch.
#
# From the HOST use `localhost`; from inside the Compose network use host `postgres`.
DATABASE_URL=postgres://supagloo:supagloo@localhost:5432/supagloo
DBOS_DATABASE_URL=postgres://supagloo:supagloo@localhost:5432/supagloo_dbos

# development | test | production (default: development)
NODE_ENV=development

# --- GitHub App + git-ops (Task #17, design-delta §2.3/§7) ---
# Required (fail-fast at boot). App-LEVEL secrets/config — one pair per app
# registration, shared by the API and DBOS, NOT per-user. The git-ops workflows sign
# short-lived App JWTs to mint installation tokens. The private key is the app's
# PKCS#1/PKCS#8 PEM (a single-line value with escaped \n is accepted).
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# GitHub REST API host (installation tokens, repo reachability, PRs) and the git
# clone/push host. Default to the real hosts — prod needs zero config. The test
# Compose overlay overrides them: GITHUB_API_BASE_URL -> the github-stub, and
# GITHUB_GIT_BASE_URL -> the local git-server (NOT the REST stub). GITHUB_GIT_BASE_URL
# is dbos-only (the API never clones); in prod it is github.com, same as git-over-HTTPS.
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_GIT_BASE_URL=https://github.com

OPENROUTER_BASE_URL=https://openrouter.ai
GLOO_BASE_URL=https://platform.ai.gloo.com
YOUVERSION_BASE_URL=https://api.youversion.com

# --- E2E provider secrets (design-delta §10.8, task 34-E2) ---
# The real-provider gating e2e suites hit the LIVE OpenRouter / Gloo / YouVersion
# APIs. The vars below are REQUIRED: a missing one must FAIL the e2e global-setup fast
# with an actionable message (34-E8) — a suite that silently skips provider tests is a
# green lie. Only YOUVERSION_E2E_ACCESS_TOKEN is deliberately optional. These are
# e2e-SETUP secrets; the fabricated-ciphertext seeding they replace is 34-E4's rework.
# CI wiring is out of scope (§9-Q12).

# YouVersion Platform API key (already wired — also the app's optional userinfo header).
YOUVERSION_APP_KEY=

# Real, live-verifiable Gloo AI client credentials. dbos-e2e live-mints a Gloo token
# (mintGlooToken) and fails setup if it fails, only then writing the encrypted row.
GLOO_CLIENT_ID=
GLOO_CLIENT_SECRET=

# A DEDICATED, LOW-BALANCE OpenRouter key (design-delta §10.3/§10.9) — the low cap is
# the backstop against a runaway media-generation suite. Never reuse a production key.
OPENROUTER_E2E_TEST_API_KEY=

# Optional (the ONE deliberately-optional real spec, design-delta §10.4b): a dedicated
# test account's YouVersion access token for the live round-trip. When unset, that spec
# skips LOUDLY (never silently). The vars above do NOT skip.
YOUVERSION_E2E_ACCESS_TOKEN=

# NOT per-user data — one key per deployment, shared by the API and DBOS.
SECRETS_ENCRYPTION_KEY=
